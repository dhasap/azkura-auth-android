<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Azkura stores TOTP secrets locally. Keep Android system cloud/device-transfer
         backup disabled; Google Drive export/restore is handled explicitly in-app. -->
    <cloud-backup>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
        <exclude domain="datastore" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="." />
        <exclude domain="sharedpref" path="." />
        <exclude domain="file" path="." />
        <exclude domain="external" path="." />
        <exclude domain="datastore" path="." />
    </device-transfer>
</data-extraction-rules>
